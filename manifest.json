{
  "manifest_version": 3,
  "name": "Kairox — автоответы OZON",
  "version": "0.1.0",
  "description": "Расширение для генерации и вставки ответов на отзывы OZON.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.sellerreply.ru/*",
    "https://seller.ozon.ru/*",
    "https://*.seller.ozon.ru/*",
    "https://*.ozon.ru/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Kairox",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://seller.ozon.ru/*",
        "https://*.seller.ozon.ru/*",
        "https://*.ozon.ru/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
